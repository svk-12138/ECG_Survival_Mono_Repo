# 卒中心电训练本地配置模板
#
# 使用方法：
# 1. 复制本文件为 configs/train_stroke_thesis.env
# 2. 只修改 train_stroke_thesis.env，不要再改 train_stroke_thesis.ps1 / .sh
# 3. train_stroke_thesis.env 已被 .gitignore 忽略，不会被提交，也不会覆盖医生本地配置
#
# 说明：
# - 路径既可以写绝对路径，也可以写相对仓库根目录的路径
# - 布尔值统一写 true / false
# - 不需要的路径留空即可

# 可选：指定 Python 可执行文件
# PYTHON_BIN="C:\Python310\python.exe"

# ==================== 必改参数 ====================
# 标签文件：必须包含 patient_id / event / time / xml_file
MANIFEST="D:\your\path\stroke_manifest.json"

# ECG 数据二选一：
# 1. 用 XML 就填 XML_DIR，把 CSV_DIR 留空
XML_DIR="D:\your\path\xml_dir"
CSV_DIR=

# 2. 用 CSV 就填 CSV_DIR，把 XML_DIR 留空
# XML_DIR=
# CSV_DIR="D:\your\path\csv_dir"

# 任务类型：
# prediction = 生存预测（主实验）
# classification = 二分类（对照实验）
TASK_MODE=prediction

# ==================== 模型选择 ====================
# 使用 MODEL_NAME 选择预设模型（推荐），会自动设置 model_type 和对应超参数。
# 可选预设：
#   tcn_light      - TCN轻量版（参数量~25k，适合1200样本）
#   resnet_small   - ResNet1d小版（参数量~12万，适合1万样本）★ 医生端推荐
#   resnet_standard- ResNet1d标准版（参数量~294万，适合10万+样本，论文同款）
#   cnn_transformer- CNN+Transformer（参数量~69万，实验性）
#
# 注意：MODEL_NAME 优先级高于下方的 MODEL_TYPE，设置 MODEL_NAME 后 MODEL_TYPE 会被忽略。
MODEL_NAME=resnet_small

# 若不使用预设，可直接指定模型架构（MODEL_NAME 留空时生效）：
# resnet        = ResNet1d（论文同款，适合10000+样本）
# tcn_light     = TCN轻量版（适合1200样本，参数量~25,000）
# cnn_transformer = CNN+Transformer（实验性，参数量过大）
MODEL_TYPE=resnet

# 导联类型：
# 8lead  = I, II, V1-V6
# 12lead = I, II, III, aVR, aVL, aVF, V1-V6
LEAD_MODE=12lead
# ==================================================

# ==================== 数据集固定划分 ====================
# 固定 train/val/test 划分文件路径。
# - 首次训练时自动生成并保存，后续每次训练自动复用，确保数据集组成完全一致。
# - 若想重新随机划分，删除该文件后重新训练即可。
# - 留空则每次随机划分（不推荐，会导致不同实验结果不可比）。
SPLIT_FILE="outputs/stroke_survival_thesis/dataset_split.json"
# ==================================================

# ==================== 常用参数 ====================
N_INTERVALS=20
MAX_TIME=1825.0

# 风险时间点：
# - 写 null 表示整个随访窗口风险
# - 写 365.0 / 1095.0 / 1825.0 表示 1年/3年/5年风险
PREDICTION_HORIZON=null

# ECG 预处理
WAVEFORM_TYPE=Rhythm
RESAMPLE_HZ=400.0
APPLY_FILTERS=true
BANDPASS_LOW_HZ=0.5
BANDPASS_HIGH_HZ=100.0
NOTCH_HZ=60.0
NOTCH_Q=30.0
TARGET_LEN=4096

# 训练参数（MODEL_NAME 预设会自动覆盖以下参数，无需手动修改）
BATCH=32
EPOCHS=80
LR=0.0005
DROPOUT=0.5
WEIGHT_DECAY=0.0001
NUM_WORKERS=0

# 留出法划分
TRAIN_RATIO=0.7
VAL_RATIO=0.15
TEST_RATIO=0.15

# 交叉验证（1=关闭，>1=启用K折，启用后 TRAIN/VAL/TEST_RATIO 被忽略）
CV_FOLDS=1
CV_SEED=42
TRAIN_SEED=42

# 早停与评估
EVAL_THRESHOLD=0.5
EARLY_STOP_METRIC=auto
EARLY_STOP_PATIENCE=15
EARLY_STOP_MIN_DELTA=0.0001
POS_WEIGHT_MULT=2.0

# 输出目录
LOG_DIR="outputs/stroke_survival_thesis"

# 设备设置
DEVICE=
USE_DATA_PARALLEL=false
DEVICE_IDS=

# 最优参数
USE_BEST_PARAMS=false
BEST_PARAMS="outputs/stroke_survival_thesis/best_params.json"
# ==================================================
