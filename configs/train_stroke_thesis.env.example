# 卒中心电训练本地配置模板
#
# 使用方法：
# 1. 复制本文件为 configs/train_stroke_thesis.env
# 2. 只修改 train_stroke_thesis.env，不要再改 train_stroke_thesis.ps1 / .sh
# 3. train_stroke_thesis.env 已被 .gitignore 忽略，不会被提交，也不会覆盖医生本地配置
#
# 说明：
# - 路径既可以写绝对路径，也可以写相对仓库根目录的路径
# - 布尔值统一写 true / false
# - 不需要的路径留空即可

# 可选：指定 Python 可执行文件
# PYTHON_BIN="C:\Python310\python.exe"

# ==================== 必改参数 ====================
# 标签文件：必须包含 patient_SN / event / time / xml_file
MANIFEST="D:\your\path\stroke_manifest.json"

# ECG 数据二选一：
# 1. 用 XML 就填 XML_DIR，把 CSV_DIR 留空
XML_DIR="D:\your\path\xml_dir"
CSV_DIR=

# 2. 用 CSV 就填 CSV_DIR，把 XML_DIR 留空
# XML_DIR=
# CSV_DIR="D:\your\path\csv_dir"

# 任务类型：
# prediction = 生存预测
# classification = 二分类
TASK_MODE=prediction

# 模型架构：
# resnet        = ResNet1d（论文同款，适合10000+样本）
# tcn_light     = TCN轻量版（适合1200样本，参数量~25,000）
# cnn_transformer = CNN+Transformer（实验性，参数量过大）
MODEL_TYPE=resnet

# 导联类型：
# 8lead  = I, II, V1-V6
# 12lead = I, II, III, aVR, aVL, aVF, V1-V6
# Windows PowerShell 脚本还支持 auto：
# auto = 从 training_inputs.json 中自动读取推荐导联模式
LEAD_MODE=12lead
# ==================================================

# ==================== 常用参数 ====================
N_INTERVALS=20
MAX_TIME=1825.0
PREDICTION_HORIZON=null

# ECG 预处理
WAVEFORM_TYPE=Rhythm
RESAMPLE_HZ=400.0
APPLY_FILTERS=true
BANDPASS_LOW_HZ=0.5
BANDPASS_HIGH_HZ=100.0
NOTCH_HZ=60.0
NOTCH_Q=30.0
TARGET_LEN=4096

# 训练参数
BATCH=32
EPOCHS=80
LR=0.0005
DROPOUT=0.5
WEIGHT_DECAY=0.0001
NUM_WORKERS=0

# 留出法划分
TRAIN_RATIO=0.8
VAL_RATIO=0.2
TEST_RATIO=0.0

# 交叉验证
CV_FOLDS=1
CV_SEED=42
TRAIN_SEED=42

# 早停与评估
EVAL_THRESHOLD=0.5
EARLY_STOP_METRIC=auto
EARLY_STOP_PATIENCE=15
EARLY_STOP_MIN_DELTA=0.0001
POS_WEIGHT_MULT=2.0

# 输出目录
LOG_DIR="outputs/stroke_survival_thesis"

# 设备设置
DEVICE=
USE_DATA_PARALLEL=false
DEVICE_IDS=

# 最优参数
USE_BEST_PARAMS=false
BEST_PARAMS="outputs/stroke_survival_thesis/best_params.json"
# ==================================================
